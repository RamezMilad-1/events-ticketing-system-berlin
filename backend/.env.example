# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Local Mongo:
MONGO_URI=mongodb://localhost:27017/EventBooking
# Atlas example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/EventBooking?retryWrites=true&w=majority

# --- Auth ---
# Use a long random string (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
JWT_SECRET=replace-with-long-random-string-please

# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Email (for forget-password OTP, optional) ---
# Leave EMAIL_HOST empty to fall back to console-logging the OTP (dev mode).
# For Gmail, generate an App Password and put it in EMAIL_PASS.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="EventHub <no-reply@eventhub.local>"

# --- OTP ---
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
